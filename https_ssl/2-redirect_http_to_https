global
    log /dev/log local0
    maxconn 2048
    user haproxy
    group haproxy
    daemon
    tune.ssl.default-dh-param 2048

defaults
    log global
    mode http
    option httplog
    option dontlognull
    timeout connect 5000
    timeout client 50000
    timeout server 50000

frontend www-http
    bind *:80
    http-request redirect scheme https code 301

frontend www-https
    bind *:443 ssl crt /etc/haproxy/certs/www.simplesuccess.tech.pem
    default_backend web-backend

backend web-backend
    balance roundrobin
    server web-01 44.211.47.49:80 check
    server web-02 3.92.183.132:80 check
